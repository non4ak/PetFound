{
  "ConnectionStrings": {
    "DataContext": "Host=localhost;Port=5432;Database=lostpet;Username=postgres;Password=123123"
  },
  "JWTConfig": {
    "Audience": "http://localhost:5173",
    "Issuer": "http://localhost:5066",
    "Key": "lostpet-secret-key-change-this-in-production-min32chars",
    "ExpirationInMinutes": "60",
    "RefreshTokenExpirationInDays": 7
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173"
    ]
  },
  "CookieOptions": {
    "AccessTokenLifetimeInMinutes": 60,
    "RefreshTokenLifeTimeInDays": 7,
    "UseSecureCookies": false,
    "SameSiteMode": "Strict"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "restrictedToMinimumLevel": "Information"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/info.log",
          "restrictedToMinimumLevel": "Information"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/error.log",
          "restrictedToMinimumLevel": "Error"
        }
      }
    ]
  },
  "ApplicationURLs": {
    "FrontEnd": "http://localhost:5173",
    "BackEnd": "http://localhost:5148"
  },
  "BackendEndpoints": {
    "ConfirmationEndpoint": "/Auth/email-confirmation"
  },
  "ClientEndpoints": {
    "EmailChangeFront": "/change-password"
  },
  "SmtpSettings": {
    "Email": "your-email@gmail.com",
    "Password": "your-app-password",
    "Host": "smtp.gmail.com",
    "HostPort": "587"
  },
  "AllowedHosts": "*"
}